@page 
@model SingularProducts.Pages.IndexModel
@{
    ViewData["Title"] = "Singular Products";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Singular Products</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
       body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
       }

       .header {
            background: linear-gradient(135deg, #0d6efd, #0dcaf0);
            color: white;
            padding: 30px 0;
            margin-bottom: 40px;
       }

       .product-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            overflow: hidden;
       }

       .product-card: hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
       }

       .product-card img {
            height: 200px;
            object-fit: cover;
            width: 100%
       }
       
       .category-badge {
            font-size: 0.75rem;
            padding: 4px 10px;
            border-radius: 20px;
       }

       .sales-summary {
        background-color: #f8f9fa;
        border-top: 1px solid #e9ecef;
        padding: 12px 16px;
        font-size: 0.85rem;
       }

       .sales-summary .stat {
            display: flex;
            justify-content: space-between;
            margin-bottom: 4px;
       }

       .stat-value{
        font-weight: 600;
        color: #0d6efd;
       }
    </style>
</head>
<body>
    <div class="header text-center">
        <h1 class="fw-bold">Singular Products</h1>
        <p class="mb-0 opacity-75">Product catalogue with sales overview</p>
    </div>

    <div class="container pb-5">

        @if (!Model.Products.Any())
        {
            <div class="alert alert-warning test-center">
                No products found. Please check the API connection
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var product in Model.Products)
                {
                    var summary = Model.SalesSummaries.ContainsKey(product.Id)
                        ?Model.SalesSummaries[product.Id]
                        : null;

                    <div class="col-sm-6 col-md-4 col-lg-3">
                        <div class="card product-card h-100">
                            <img src="@product.Image"
                                alt="@product.Description"
                                onerror="this.src='https://via.placeholder.com/300x200?text=No+Image'" />
                            
                            <div class="card-body">
                                <span class="badge bg-info text-dark category-badge mb-2">
                                    @product.Category
                                </span>
                                <h6 class="card-title fw-bold">@product.Description</h6>
                                <p class="text-success fw-semibold mb-0">
                                    R @product.SalePrice.ToString("N2")
                                </p>
                            </div>

                            @if (summary!= null){
                                <div class="sales-summary">
                                    <div class="stat">
                                        <span class="text-muted">Units sold</span>
                                        <span class="stat-value">@summary.TotalUnitsSold</span>
                                    </div>
                                    <div class="stat">
                                        <span class="text-muted">Total Revenue</span>
                                        <span class="stat-value"> R @summary.TotalRevenue.ToString("N2")</span>
                                    </div>
                                    <div class="stat">
                                        <span class="text-muted">Last Sale</span>
                                        <span class="stat-value">
                                            @(summary.LastSaleDate.HasValue
                                                ? summary.LastSaleDate.Value.ToString("dd MMM yyyy")
                                                : "N/A")
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
